# Convex — copy to `.env.local`. Values come from the dashboard (Development deployment summary).
# CONVEX_DEPLOYMENT=dev:<deployment-name>   # e.g. dev:basic-ostrich-949
# NEXT_PUBLIC_CONVEX_URL=https://<deployment-name>.convex.cloud
# NEXT_PUBLIC_CONVEX_SITE_URL=https://<deployment-name>.convex.site
CONVEX_DEPLOYMENT=
NEXT_PUBLIC_CONVEX_URL=
NEXT_PUBLIC_CONVEX_SITE_URL=
